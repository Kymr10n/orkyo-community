<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Only nuget.org here. The GitHub Packages source is added dynamically:
       - In Dockerfiles: via `dotnet nuget add source` when nuget_token secret is present
       - In CI workflows: via `dotnet nuget add source` step before restore
       This avoids NuGet rejecting an absent/empty credential at startup. -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
