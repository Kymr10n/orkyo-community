<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/Kymr10n/index.json" />
  </packageSources>
  <!-- Credentials read from NUGET_AUTH_TOKEN env var — never store tokens here -->
  <packageSourceCredentials>
    <github>
      <add key="Username" value="Kymr10n" />
      <add key="ClearTextPassword" value="%NUGET_AUTH_TOKEN%" />
    </github>
  </packageSourceCredentials>
</configuration>
