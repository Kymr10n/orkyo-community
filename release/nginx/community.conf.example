# Orkyo Community — Nginx Reverse Proxy Reference
#
# This file is a REFERENCE ONLY. Nginx configuration is the operator's
# responsibility. Adapt paths, server names, and TLS settings to your environment.
#
# Architecture:
#   Internet → nginx (TLS termination) → frontend container (port 80)
#                                          └── /api/* proxied internally to api container
#
# The frontend container's built-in nginx handles /api/ → backend routing.
# No split-routing is needed here — proxy all traffic to port 80.
#
# Prerequisites:
#   - Obtain TLS certificates (Let's Encrypt / certbot recommended)
#   - Replace community.example.com with your actual domain
#   - Replace /etc/ssl/... paths with your certificate locations

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    listen 80;
    server_name community.example.com;
    return 301 https://$host$request_uri;
}

# ── HTTPS — main application ──────────────────────────────────────────────────
server {
    listen 443 ssl;
    http2 on;
    server_name community.example.com;

    ssl_certificate     /etc/ssl/certs/community.example.com.crt;
    ssl_certificate_key /etc/ssl/private/community.example.com.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    # Security headers
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Max upload size (match FILE_STORAGE_PATH limits in your .env)
    client_max_body_size 10M;

    # Proxy all traffic to the frontend container.
    # The frontend's internal nginx handles /api/ → backend routing.
    location / {
        proxy_pass http://127.0.0.1:80;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts — increase if you have slow API operations
        proxy_connect_timeout 10s;
        proxy_read_timeout    120s;
        proxy_send_timeout    120s;
    }
}
