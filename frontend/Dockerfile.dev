FROM node:26.5.0-alpine
WORKDIR /app

# GitHub Packages token for @kymr10n/foundation. Passed via BuildKit secret
# (id=npm_token, mapped from GHCR_TOKEN in compose.local.yml). The secret is
# mounted only during the npm install RUN step and never stored in any layer.

# Create the foundation mount point, symlink it, and fix /app ownership as root
# before dropping privileges — /orkyo-foundation is root-owned so the symlink
# must be created here, and /app needs chown so the node user can write to it.
RUN mkdir -p /orkyo-foundation \
    && ln -s /foundation /orkyo-foundation/frontend \
    && chown node:node /app

# Switch to node user before installing so node_modules is owned correctly
# from the start, avoiding an expensive chown -R /app at the end.
USER node

# Copy package files and install. The docker-entrypoint.sh will re-install
# if node_modules is absent or empty (e.g. fresh named volume).
# The GitHub Packages token is passed via BuildKit secret (never baked into layers).
COPY --chown=node:node package*.json ./
# The postinstall hook (npm install, below) runs scripts/sync-foundation-build.mjs,
# so scripts/ must be present before the install step (mirrors the prod Dockerfile).
COPY --chown=node:node scripts ./scripts
RUN --mount=type=secret,id=npm_token,uid=1000 \
    echo "@kymr10n:registry=https://npm.pkg.github.com" > .npmrc \
    && echo "//npm.pkg.github.com/:_authToken=$(cat /run/secrets/npm_token)" >> .npmrc \
    && npm install \
    && rm -f .npmrc

# Copy source and entrypoint (src/ and public/ will be overridden by
# read-only volume mounts in docker compose dev for hot-reload).
COPY --chown=node:node . .
RUN chmod +x docker-entrypoint.sh

EXPOSE 5173

ENTRYPOINT ["./docker-entrypoint.sh"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
